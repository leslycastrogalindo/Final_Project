                    <p class="text-emerald-400 font-medium">"You've been consistent, but Wednesdays are your friction point."</p>
                </div>
            </div>
        </section>

        <section id="view-chat" class="view-content hidden flex flex-col h-full p-8">
            <div id="chat-history" class="flex-1 overflow-y-auto space-y-4 mb-4">
                <div class="bg-zinc-900 p-4 rounded-lg max-w-2xl">Coach: How are you feeling about your goals today?</div>
            </div>
            <div class="flex gap-2">
                <input id="chat-input" class="flex-1 bg-zinc-900 border border-zinc-800 rounded p-4 focus:outline-emerald-500" placeholder="Talk to your coach...">
                <button onclick="sendMessage()" class="bg-emerald-600 px-8 rounded font-bold">Send</button>
            </div>
        </section>

        <section id="view-roadmap" class="view-content hidden p-8">
            <h2 class="text-3xl font-bold mb-6">Your Long-Term Roadmap</h2>
